set(NO_EXAMPLES ON CACHE BOOL "" FORCE)
set(NO_TESTS ON CACHE BOOL "" FORCE)
set(BUILD_SHARED_LIBS ON CACHE BOOL "Build libraries as shared" FORCE)
set(WARNINGS_AS_ERRORS OFF CACHE BOOL "" FORCE)

set(PREFER_SYSTEM_LIB OFF CACHE BOOL "" FORCE)
set(USE_SYSTEM_SRTP OFF CACHE BOOL "" FORCE)
set(USE_SYSTEM_PLOG OFF CACHE BOOL "" FORCE)
set(USE_SYSTEM_USRSCTP OFF CACHE BOOL "" FORCE)
set(USE_SYSTEM_JSON OFF CACHE BOOL "" FORCE)
set(USE_SYSTEM_JUICE OFF CACHE BOOL "" FORCE)
set(USE_GNUTLS OFF CACHE BOOL "" FORCE)
set(USE_MBEDTLS OFF CACHE BOOL "" FORCE)
set(NO_MEDIA OFF CACHE BOOL "Enable media support in libdatachannel for RTP/H264 handlers" FORCE)

add_subdirectory("${THIRD_PARTY_DIR}/libdatachannel")
set(LIBDATACHANNEL_INCLUDE_DIR "${THIRD_PARTY_DIR}/libdatachannel/include" CACHE PATH "libdatachannel include directory")

if(MSVC)
    foreach(_libdatachannel_target datachannel datachannel-static usrsctp)
        if(TARGET ${_libdatachannel_target})
            target_compile_options(${_libdatachannel_target} PRIVATE /wd4244)
        endif()
    endforeach()
endif()

if(TARGET OpenSSL::Crypto)
    if(TARGET datachannel)
        target_link_libraries(datachannel PRIVATE OpenSSL::Crypto OpenSSL::SSL)
    elseif(TARGET datachannel-static)
        target_link_libraries(datachannel-static PRIVATE OpenSSL::Crypto OpenSSL::SSL)
    endif()
endif()
